#!/usr/bin/env python3
"""history — reconstruction-view daemon: read-only history queries over HTTP.

Doctrine (docs/bus.md, [DECIDED] flight recorder vs reconstruction views):
the ledger and transcripts in sqlite are the truth; views that rebuild
reality from them are userland subscribers. This is the first one. It holds
NO state of its own — every query is answered by a fresh read-only sqlite
connection, so the answer is exactly as good as the ledger at that instant.

Transport (2026-06-12, HANDOFF phase 3): HTTP on the harness-negotiated
loopback port (ELANUS_HTTP_PORT; consumers discover it from
run/pkg-history/http.json — harness state, never retained bus messages).
The old obs/ui/history q/r protocol is retired: result sets, pagination and
projection want status codes and bodies, not pub/sub. Serving is a granted
capability (kind "http" in the ledger): transcripts are the crown jewels
(docs/security.md entry 10), so this parks until `elanus approve history`.

  POST /query   one JSON body, dispatched on "kind":
    agents                          -> {"agents":[{"agent","sessions":[...]}], "orphan_sessions":[...]}
    sessions     {agent?}           -> {"sessions":[{"session","first_ts","last_ts","message_count","event_count"}]}
    transcript   {session, limit?, before_id?}
                                    -> {"session","messages":[...],"has_more"}
    conversation {correlation}      -> {"correlation","events":[...],"truncated"}
    search       {filter?, select?, page?}   the query DSL (filter x
                 projection x pagination over transcript messages):
      filter:  {channels: ["in/agent/main", ...],   event-type prefixes
                involvement: "agent"|"all",         (default all)
                roles: ["user","assistant","tool"],
                text: "substring"}                  matched in content
      select:  {tool_calls: true|false,             drop assistant tool_calls
                tool_results: true|{"truncate": N}|false}
      page:    {limit: 100, cursor: "<opaque>"}     cursor = last seen id
  GET /healthz  -> {"ok": true}

The DSL is INTERPRETED — parameters bind, nothing concatenates into SQL
(entry 10). Crash-only: any fault exits nonzero and the supervisor restarts
us with backoff.
"""
import json
import os
import sqlite3
import sys
import time
from http.server import HTTPServer, BaseHTTPRequestHandler

DB = os.environ.get("ELANUS_DB") or os.environ.get("HARNESS_DB") or os.path.join(os.environ.get("ELANUS_ROOT") or os.environ.get("HARNESS_ROOT", "."), "elanus.db")
PAGE_DEFAULT = 80
PAGE_MAX = 200
CONTENT_CAP = 16 * 1024
CONV_CAP = 500


def log(msg):
    print(msg, file=sys.stderr, flush=True)


def ro():
    """Fresh READ-ONLY connection per query. mode=ro is load-bearing: a view
    must be physically unable to write the truth it reconstructs."""
    conn = sqlite3.connect(f"file:{DB}?mode=ro", uri=True, timeout=5)
    conn.row_factory = sqlite3.Row
    return conn


def capped_json(text):
    """Parse stored JSON; oversized content becomes an honest stub instead of
    an oversized response body nobody asked for."""
    if text is None:
        return None
    if len(text) > CONTENT_CAP:
        return {"truncated": True, "chars": len(text), "preview": text[:2048]}
    try:
        return json.loads(text)
    except (ValueError, TypeError):
        return text


def agent_of(event_type):
    seg = (event_type or "").split("/")
    return seg[2] if len(seg) >= 3 and seg[0] == "in" and seg[1] == "agent" else None


# ---- query kinds ------------------------------------------------------------

def q_agents(c, q):
    nouns = set()
    for (t,) in c.execute("SELECT DISTINCT type FROM events WHERE type LIKE 'in/agent/%'"):
        a = agent_of(t)
        if a:
            nouns.add(a)
    by_agent = {n: set() for n in nouns}
    orphans = set()
    rows = c.execute(
        """SELECT DISTINCT m.session_id, e.type
           FROM messages m LEFT JOIN events e ON m.event_id = e.id"""
    )
    for sid, etype in rows:
        a = agent_of(etype)
        if a:
            by_agent.setdefault(a, set()).add(sid)
            orphans.discard(sid)
        elif not any(sid in s for s in by_agent.values()):
            orphans.add(sid)
    return {
        "agents": [{"agent": a, "sessions": sorted(by_agent[a])} for a in sorted(by_agent)],
        "orphan_sessions": sorted(orphans - {s for v in by_agent.values() for s in v}),
    }


def q_sessions(c, q):
    agent = q.get("agent")
    sql = """SELECT m.session_id AS session, MIN(m.created_at) AS first_ts,
                    MAX(m.created_at) AS last_ts, COUNT(*) AS message_count,
                    COUNT(DISTINCT m.event_id) AS event_count
             FROM messages m"""
    params = []
    if agent:
        sql += """ WHERE EXISTS (
                     SELECT 1 FROM messages m2 JOIN events e ON m2.event_id = e.id
                     WHERE m2.session_id = m.session_id
                       AND (e.type = 'in/agent/' || ?1 OR e.type LIKE 'in/agent/' || ?1 || '/%'))"""
        params.append(agent)
    sql += " GROUP BY m.session_id ORDER BY last_ts DESC LIMIT 500"
    return {"sessions": [dict(r) for r in c.execute(sql, params)]}


def q_transcript(c, q):
    session = q.get("session")
    if not session:
        raise ValueError("transcript needs {session}")
    limit = max(1, min(int(q.get("limit") or PAGE_DEFAULT), PAGE_MAX))
    before = q.get("before_id")
    sql = "SELECT id, role, content, event_id, created_at FROM messages WHERE session_id = ?"
    params = [session]
    if before is not None:
        sql += " AND id < ?"
        params.append(int(before))
    sql += " ORDER BY id DESC LIMIT ?"
    params.append(limit + 1)
    rows = list(c.execute(sql, params))
    has_more = len(rows) > limit
    rows = rows[:limit]
    rows.reverse()
    return {
        "session": session,
        "messages": [
            {"id": r["id"], "role": r["role"], "content": capped_json(r["content"]),
             "event_id": r["event_id"], "created_at": r["created_at"]}
            for r in rows
        ],
        "has_more": has_more,
    }


def q_conversation(c, q):
    corr = q.get("correlation")
    if not corr:
        raise ValueError("conversation needs {correlation}")
    rows = list(c.execute(
        """SELECT id, type, cause_id, state, payload, created_at
           FROM events WHERE correlation_id = ? ORDER BY id ASC LIMIT ?""",
        (corr, CONV_CAP + 1),
    ))
    truncated = len(rows) > CONV_CAP
    rows = rows[:CONV_CAP]
    return {
        "correlation": corr,
        "events": [
            {"id": r["id"], "type": r["type"], "cause_id": r["cause_id"], "state": r["state"],
             "payload": capped_json(r["payload"]), "created_at": r["created_at"]}
            for r in rows
        ],
        "truncated": truncated,
    }


def q_search(c, q):
    """The DSL: filter x projection x pagination over transcript messages.
    Every value BINDS as a parameter; the only SQL assembled is fixed
    clause text chosen by key presence — nothing user-supplied is code."""
    f = q.get("filter") or {}
    sel = q.get("select") or {}
    page = q.get("page") or {}

    where = ["1=1"]
    params = []
    channels = f.get("channels") or []
    if channels:
        if not isinstance(channels, list) or len(channels) > 20:
            raise ValueError("filter.channels: a list of up to 20 type prefixes")
        ors = []
        for ch in channels:
            ors.append("(e.type = ? OR e.type LIKE ? || '/%')")
            params.extend([str(ch), str(ch)])
        where.append("(" + " OR ".join(ors) + ")")
    if f.get("involvement") == "agent":
        where.append("e.type LIKE 'in/agent/%'")
    roles = f.get("roles") or []
    if roles:
        if not isinstance(roles, list) or any(r not in ("user", "assistant", "tool") for r in roles):
            raise ValueError("filter.roles: subset of user|assistant|tool")
        where.append("m.role IN (%s)" % ",".join("?" * len(roles)))
        params.extend(roles)
    text = f.get("text")
    if text:
        where.append("m.content LIKE '%' || ? || '%' ESCAPE '\\'")
        params.append(str(text).replace("\\", "\\\\").replace("%", r"\%").replace("_", r"\_"))
    # ISO-8601 bounds compare lexicographically against created_at (the
    # ledger stores strftime ISO UTC, so string order IS time order).
    for key, op in (("since", ">="), ("until", "<")):
        v = f.get(key)
        if v:
            where.append(f"m.created_at {op} ?")
            params.append(str(v))

    limit = max(1, min(int(page.get("limit") or PAGE_DEFAULT), PAGE_MAX))
    cursor = page.get("cursor")
    if cursor:
        where.append("m.id < ?")
        params.append(int(cursor))

    sql = (
        "SELECT m.id, m.session_id, m.role, m.content, m.event_id, m.created_at, e.type AS event_type"
        " FROM messages m LEFT JOIN events e ON m.event_id = e.id"
        " WHERE " + " AND ".join(where) + " ORDER BY m.id DESC LIMIT ?"
    )
    params.append(limit + 1)
    rows = list(c.execute(sql, params))
    has_more = len(rows) > limit
    rows = rows[:limit]

    want_tool_calls = sel.get("tool_calls", True)
    # reasoning: True keeps what the transcript recorded, False strips it.
    # (The real-vs-summary distinction awaits provider metadata the
    # transcript doesn't carry yet — recorded in SKILL.md, not pretended.)
    want_reasoning = sel.get("reasoning", True)
    tr = sel.get("tool_results", True)
    out = []
    for r in rows:
        content = capped_json(r["content"])
        if isinstance(content, dict):
            if r["role"] == "assistant" and not want_tool_calls:
                content = {k: v for k, v in content.items() if k != "tool_calls"}
            if r["role"] == "assistant" and not want_reasoning:
                content = {k: v for k, v in content.items() if k != "reasoning"}
            if r["role"] == "tool":
                if tr is False:
                    continue  # projected out entirely
                if isinstance(tr, dict) and isinstance(tr.get("truncate"), int):
                    n = max(0, tr["truncate"])
                    inner = content.get("content")
                    if isinstance(inner, str) and len(inner) > n:
                        content["content"] = inner[:n] + "…"
                        content["truncated_to"] = n
        out.append({
            "id": r["id"], "session": r["session_id"], "role": r["role"],
            "event_id": r["event_id"], "event_type": r["event_type"],
            "created_at": r["created_at"], "content": content,
        })
    return {
        "messages": out,
        "has_more": has_more,
        "cursor": rows[-1]["id"] if has_more and rows else None,
    }


KINDS = {"agents": q_agents, "sessions": q_sessions, "transcript": q_transcript,
         "conversation": q_conversation, "search": q_search}


# ---- wire -------------------------------------------------------------------

class Handler(BaseHTTPRequestHandler):
    def _send(self, code, body):
        data = json.dumps(body).encode()
        self.send_response(code)
        self.send_header("content-type", "application/json")
        self.send_header("content-length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def do_GET(self):
        if self.path == "/healthz":
            self._send(200, {"ok": True, "kinds": sorted(KINDS)})
        else:
            self._send(404, {"ok": False, "error": "POST /query or GET /healthz"})

    def do_POST(self):
        if self.path != "/query":
            self._send(404, {"ok": False, "error": "POST /query"})
            return
        try:
            n = int(self.headers.get("content-length", 0))
            q = json.loads(self.rfile.read(n).decode())
            if not isinstance(q, dict):
                raise ValueError("body must be a JSON object")
        except ValueError as e:
            self._send(400, {"ok": False, "error": f"bad request body: {e}"})
            return
        fn = KINDS.get(q.get("kind"))
        if fn is None:
            self._send(400, {"ok": False, "error": f"unknown kind {q.get('kind')!r}", "kinds": sorted(KINDS)})
            return
        try:
            with ro() as c:
                body = fn(c, q)
            body.update(ok=True, kind=q["kind"])
            self._send(200, body)
        except (ValueError, OverflowError, TypeError) as e:  # the requester's problem
            self._send(400, {"ok": False, "kind": q.get("kind"), "error": str(e)})
        except sqlite3.Error as e:
            self._send(500, {"ok": False, "kind": q.get("kind"), "error": str(e)})

    def log_message(self, *a):  # obs-quiet; faults go to stderr explicitly
        pass


def http_grant_approved():
    """Serving is a capability (grants kind 'http'); park until approved —
    `elanus approve history` flips this without a restart dance."""
    try:
        with ro() as c:
            row = c.execute(
                "SELECT state FROM grants WHERE package = ? AND kind = 'http'"
                " ORDER BY id DESC LIMIT 1",
                (os.environ.get("ELANUS_PACKAGE", "history"),),
            ).fetchone()
        return row is not None and row["state"] == "approved"
    except sqlite3.Error:
        return False


def main():
    if not os.path.exists(DB):
        log(f"[history] no ledger at {DB}; the path is supervisor-given, so a missing db is a real fault")
        sys.exit(1)
    port = os.environ.get("ELANUS_HTTP_PORT")
    if not port:
        log("[history] no ELANUS_HTTP_PORT (needs a daemon with process.http support); exiting")
        sys.exit(1)
    waited = False
    while not http_grant_approved():
        if not waited:
            log("[history] http grant not approved yet; parking until `elanus approve history` (this is not an error)")
            waited = True
        time.sleep(2)
    srv = HTTPServer(("127.0.0.1", int(port)), Handler)
    log(f"[history] serving http://127.0.0.1:{port} (db {DB}, read-only)")
    srv.serve_forever()


if __name__ == "__main__":
    main()
