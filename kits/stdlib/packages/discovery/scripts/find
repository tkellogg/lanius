#!/usr/bin/env python3
"""discovery `find_capability` tool (docs/handoffs/kb-discovery.md M2).

exec-mode tool over the `[[tool]]` seam: the call args arrive as JSON on stdin
({"query": ...}) and the reshaped discovery report goes out as JSON on stdout.

A THIN wrapper (wonky bit 2): the privileged universe scan lives ONCE in the
kernel CLI (`lanius discover --json`); this script only shells it with the
calling agent's profile (LANIUS_PROFILE) and reshapes the report into a tool
result the model reads. It does NOT re-scan package dirs — that would duplicate
manifest parsing in a package script and drift from the kernel.
"""
import json
import os
import subprocess
import sys


def emit(obj):
    sys.stdout.write(json.dumps(obj))
    sys.stdout.flush()


def main():
    try:
        args = json.load(sys.stdin)
    except (ValueError, TypeError):
        args = {}
    query = (args.get("query") or "").strip()
    if not query:
        emit({"error": "find_capability: 'query' is required"})
        return

    # The kernel binary — `lanius` on PATH is how packages shell the CLI (the
    # index daemon and history package do the same).
    profile = os.environ.get("LANIUS_PROFILE") or os.environ.get("ELANUS_PROFILE") or "default"
    try:
        out = subprocess.run(
            ["lanius", "discover", "--json", "--profile", profile, query],
            capture_output=True,
            text=True,
            timeout=12,
        )
    except (OSError, subprocess.TimeoutExpired) as e:
        emit({"error": f"find_capability: could not run `lanius discover`: {e}"})
        return
    if out.returncode != 0:
        emit({"error": f"find_capability: `lanius discover` failed: {out.stderr.strip()}"})
        return
    try:
        report = json.loads(out.stdout)
    except (ValueError, TypeError):
        emit({"error": "find_capability: could not parse the discovery report",
              "raw": out.stdout[:500]})
        return

    matches = report.get("matches", [])
    if not matches:
        emit({
            "query": query,
            "found": [],
            "message": "no available-but-disabled capability matches — everything "
                       "matching your query is already on your path.",
        })
        return

    # Reshape into a compact, model-legible result: one entry per package with
    # what enabling adds and the enable path.
    found = []
    for m in matches:
        adds = m.get("adds", {})
        found.append({
            "package": m.get("package"),
            "matched": m.get("matched", []),
            "adds": {
                k: v for k, v in {
                    "kb": adds.get("kb", []),
                    "skills": adds.get("skills", []),
                    "tools": adds.get("tools", []),
                    "stages": adds.get("stages", []),
                    "mcp": adds.get("mcp", []),
                    "harnesses": adds.get("harnesses", []),
                    "builtin_tools": adds.get("builtin_tools", []),
                }.items() if v
            },
            "enable": m.get("enable"),
        })
    emit({"query": query, "found": found})


if __name__ == "__main__":
    main()
