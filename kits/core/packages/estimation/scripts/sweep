#!/usr/bin/env python3
"""estimation sweep — the E3 retro BACKSTOP (docs/handoffs/work-estimation.md).

The primary retro runs on the coding agent's Stop/SessionEnd hook, inside the
kernel: when a session that declared an estimate ends, the kernel appends the
miss to the durable `estimation` block. This cron-driven script is the safety
net for sessions whose hook never fired — a crashed worker, a killed harness.

It is intentionally dumb and idempotent: list the finished coding sessions from
the obs projection, and for each one run `elanus estimate retro`. That verb is
once-per-session (it writes a session-scope `estimation-retro-done` marker block
the first time and returns "skipped" thereafter), so a session the hook already
retro'd, or that this sweep already swept, records NOTHING the second time. The
sweep therefore never double-counts and is safe to run every 10 minutes.

No estimation data model is touched here: this only shells out to the kernel CLI
verbs, which themselves only read the obs projection and write memory blocks.
"""
import json
import os
import subprocess
import sys

ROOT = os.environ.get("ELANUS_ROOT") or os.environ.get("HARNESS_ROOT")


def elanus(*args):
    cmd = ["elanus"]
    if ROOT:
        cmd += ["--root", ROOT]
    cmd += list(args)
    return subprocess.run(cmd, capture_output=True, text=True)


def main():
    # The materialized projection: one row per coding session/thread.
    listed = elanus("code", "sessions", "--json")
    if listed.returncode != 0:
        # No projection yet, or the CLI is unavailable — nothing to sweep.
        return 0
    try:
        sessions = json.loads(listed.stdout or "[]")
    except json.JSONDecodeError:
        return 0

    for s in sessions:
        # Only finished sessions get a retro; a running/idle one isn't done yet.
        if s.get("last_status") != "done":
            continue
        session = s.get("elanus_session")
        owner = s.get("agent_noun")  # the agent noun owns the estimate blocks
        if not session or not owner:
            continue
        # retro is once-per-session (marker block); a session with no estimate, or
        # one already retro'd by the Stop hook or a prior sweep, is a no-op.
        r = elanus("estimate", "retro", "--session", session, "--owner", owner)
        if r.returncode == 0 and "updated" in r.stdout:
            print(f"estimation: retro recorded for {session}", file=sys.stderr)
    return 0


if __name__ == "__main__":
    sys.exit(main())
