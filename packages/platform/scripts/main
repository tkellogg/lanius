#!/usr/bin/env python3
"""platform — the computed context stage (docs/handoffs/platform-trust.md).

A stage is a Doc->Doc transform; a "computed block" is just a stage that
appends to doc.system (the same {name, text} shape every static/persisted
block uses — no special block type, no kernel API). This one reads the
installation's platform trust level and web/network exposure from bus.toml and
pushes a `platform` system block, so the agent knows whether the raw HTML it
sends in chat will render and how exposed the machine is.

bus.toml is the root-wide config the cage fences from agents: readable here,
never writable, so an agent cannot read this block and then raise its own
trust. Missing/empty/unparseable bus.toml ⇒ full (the kernel's own default).
"""
import json
import os
import sys

ROOT = os.environ.get("ELANUS_ROOT") or os.environ.get("HARNESS_ROOT") or "."
BUS = os.path.join(ROOT, "bus.toml")


def read_bus():
    """Return (trust, bind) from bus.toml. Defaults: trust=full, bind loopback.

    Parses with tomllib when available (py3.11+); falls back to a tiny line
    scan for the two flat keys we need, so the stage never fails closed on an
    older interpreter.
    """
    trust = "full"
    bind = "127.0.0.1:1883"
    try:
        with open(BUS, "rb") as f:
            raw = f.read()
    except OSError:
        return trust, bind
    try:
        import tomllib

        cfg = tomllib.loads(raw.decode("utf-8"))
        return str(cfg.get("trust", trust)), str(cfg.get("bind", bind))
    except Exception:
        pass
    # Fallback: flat `key = "value"` lines, comments and whitespace tolerated.
    for line in raw.decode("utf-8", "replace").splitlines():
        s = line.split("#", 1)[0].strip()
        if "=" not in s:
            continue
        k, _, v = s.partition("=")
        k = k.strip()
        v = v.strip().strip('"').strip("'")
        if k == "trust":
            trust = v
        elif k == "bind":
            bind = v
    return trust, bind


def is_loopback(bind):
    host = bind.rsplit(":", 1)[0].strip("[]") if ":" in bind else bind
    return host in ("127.0.0.1", "localhost", "::1") or host.startswith("127.")


def block_text(trust, bind):
    trust = (trust or "full").strip().lower()
    if trust == "reduced":
        line1 = ("Trust level: reduced — this is a shared or remote machine. "
                 "HTML you put in a message is shown as escaped text, not live "
                 "interface elements, and high-stakes actions need a person's gesture.")
    else:
        line1 = ("Trust level: full — this is a trusted personal machine. "
                 "Raw HTML you put in a chat message renders as real interface "
                 "elements (small UI and forms are fine). You may reply with a "
                 "whole HTML fragment — a form or button-bar that continues the "
                 "conversation — by setting format=\"html\" on send_message or "
                 "ask_human; inline HTML inside an ordinary markdown message "
                 "renders too, for small touches.")
    if is_loopback(bind):
        line2 = "Web dashboard: reachable only from this machine (loopback)."
    else:
        line2 = ("Web dashboard: reachable from the network (the bus listener is "
                 "bound beyond loopback) — treat this machine as exposed.")
    return "## Platform\n- " + line1 + "\n- " + line2


def main():
    doc = json.load(sys.stdin)
    trust, bind = read_bus()
    doc.setdefault("system", []).append({
        "name": "platform",
        "text": block_text(trust, bind),
    })
    json.dump(doc, sys.stdout)


if __name__ == "__main__":
    main()
