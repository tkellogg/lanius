#!/usr/bin/env python3
"""Surface human/ask / signal/# events as a macOS notification (no-op elsewhere).

Arguments are passed to osascript via argv, never spliced into the script
source: event payloads are untrusted input and must not become AppleScript.
"""
import json
import subprocess
import sys

event = json.load(sys.stdin)
payload = event.get("payload") or {}
etype = event.get("type", "event")

title = f"elanus: {etype}"
body = payload.get("question") or payload.get("reason") or json.dumps(payload)[:160]
options = payload.get("options")
if options:
    body += "  [" + " | ".join(str(o) for o in options) + "]"
if etype == "human/ask":
    body += f'  — answer: elanus answer {event.get("id")} "..."'

script = 'on run argv\ndisplay notification (item 2 of argv) with title (item 1 of argv)\nend run'
ok = False
try:
    r = subprocess.run(["osascript", "-e", script, title, body[:220]], check=False, timeout=10)
    ok = r.returncode == 0
except Exception:
    pass

# The receipt: "we attempted delivery on this channel, and it did/didn't
# work". sent != acked — acked means a human demonstrably saw it, which the
# desktop channel cannot know. Escalation logic keys off these.
if etype == "human/ask":
    receipt = json.dumps({"ask_id": event.get("id"), "channel": "desktop", "ok": ok})
    try:
        subprocess.run(
            ["elanus", "emit", "delivery/desktop/sent", "--payload", receipt,
             "--cause", str(event.get("id"))],
            check=False, timeout=10,
        )
    except Exception:
        pass
print(body)
