#!/usr/bin/env python3
# Context stage (docs/context.md): document JSON on stdin, transformed
# document on stdout. Injects a "Recent mail" system block — the last
# exchanges between this agent and its humans, read from the ledger
# (sqlite, READ-ONLY via mode=ro: reconstruction views never write truth).
import json
import os
import sqlite3
import sys

LIMIT = 12
CLIP = 300

doc = json.load(sys.stdin)
agent = doc.get("meta", {}).get("agent", "main")
current_id = (doc.get("event") or {}).get("id")

db = os.path.join(os.environ["HARNESS_ROOT"], "harness.db")
conn = sqlite3.connect(f"file:{db}?mode=ro", uri=True)
rows = conn.execute(
    """SELECT id, type, payload, created_at FROM events
       WHERE (type = ? OR type LIKE 'in/human/%')
       ORDER BY id DESC LIMIT ?""",
    (f"in/agent/{agent}", LIMIT + 1),
).fetchall()
conn.close()

lines = []
for eid, etype, payload, created in reversed(rows):
    if current_id is not None and eid == current_id:
        continue  # the dispatching event IS the user message; don't echo it
    try:
        p = json.loads(payload) if payload else {}
    except ValueError:
        p = {}
    text = p.get("text") or p.get("prompt") or p.get("answer") or ""
    if not isinstance(text, str) or not text.strip():
        continue
    text = " ".join(text.split())
    if len(text) > CLIP:
        text = text[:CLIP] + "…"
    lines.append(f"- [{created}] {etype}: {text}")

if lines:
    doc["system"].append({
        "name": "recent-history",
        "text": "## Recent mail (reconstructed from the ledger each call; "
                "sessions are fresh by design)\n" + "\n".join(lines[-LIMIT:]),
    })

json.dump(doc, sys.stdout)
