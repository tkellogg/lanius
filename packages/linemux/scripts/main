#!/bin/sh
# linemux: bridge $ELANUS_SCRATCH/inbox/*.line files onto the bus.
# Crash-only: any bus failure exits nonzero; the supervisor restarts us
# with backoff and publishes our retained liveness either way.
set -u

INBOX="$ELANUS_SCRATCH/inbox"
mkdir -p "$INBOX"

while true; do
  for f in "$INBOX"/*.line; do
    [ -e "$f" ] || continue
    payload=$(python3 -c '
import json, sys, datetime
# Cap the read: a giant file must not become an oversized publish that the
# broker rejects every restart, wedging the bridge in a retry loop.
CAP = 64 * 1024
with open(sys.argv[1], encoding="utf-8", errors="replace") as fh:
    text = fh.read(CAP + 1)
truncated = len(text) > CAP
text = text[:CAP].strip()
print(json.dumps({
    "text": text,
    "truncated": truncated,
    "source": "linemux",
    "received_at": datetime.datetime.now(datetime.timezone.utc).isoformat(),
}))' "$f") || { rm -f "$f"; continue; }
    # One addressed publish (QoS 1: PUBACK means the kernel accepted it).
    # Only delete the file once the work item is in.
    elanus bus pub in/package/linemux/triage "$payload" --qos 1 || exit 1
    rm -f "$f"
  done
  sleep 1
done
