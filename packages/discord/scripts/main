#!/usr/bin/env python3
"""Discord ingress bridge — UNTESTED SCAFFOLD (written without a live token).

Inbound: gateway MESSAGE_CREATE -> `ingress/discord/message` (observation)
plus `work/discord/triage` (ledger-backed, so triage handlers run).
Outbound: subscribes `work/discord/send` {channel_id, content} -> REST post,
then a `delivery/discord/sent` receipt.

Bus access rides the `elanus bus` CLI as subprocesses — the CLI
authenticates from the supervisor-injected env (ELANUS_PACKAGE /
ELANUS_BUS_TOKEN), so this script holds no credentials for the bus itself.
Crash-only: any bus or gateway failure exits nonzero; the supervisor
restarts with backoff. Unconfigured (no DISCORD_TOKEN or no `websockets`
module), it parks forever instead of crash-looping.
"""
import json
import os
import subprocess
import sys
import threading
import time
import urllib.request

TOKEN = os.environ.get("DISCORD_TOKEN", "")
GATEWAY = "wss://gateway.discord.gg/?v=10&encoding=json"
API = "https://discord.com/api/v10"


def log(msg):
    print(msg, file=sys.stderr, flush=True)


def park(reason):
    log(f"[discord] not configured: {reason}; parking (this is not an error)")
    while True:
        time.sleep(3600)


def bus_pub(topic, payload, qos=1):
    subprocess.run(
        ["elanus", "bus", "pub", topic, json.dumps(payload), "--qos", str(qos)],
        check=True, timeout=30,
    )


def rest_post(path, body):
    req = urllib.request.Request(
        f"{API}{path}",
        data=json.dumps(body).encode(),
        headers={"Authorization": f"Bot {TOKEN}", "Content-Type": "application/json"},
        method="POST",
    )
    with urllib.request.urlopen(req, timeout=15) as r:
        return json.load(r)


def outbound_loop():
    """work/discord/send -> REST post -> delivery receipt. Reads the
    `elanus bus sub` subprocess line-by-line; each line is
    {"topic":..., "payload": <envelope>}."""
    proc = subprocess.Popen(
        ["elanus", "bus", "sub", "work/discord/send"],
        stdout=subprocess.PIPE, text=True,
    )
    for line in proc.stdout:
        try:
            payload = json.loads(line)["payload"].get("payload") or {}
            channel, content = payload["channel_id"], payload["content"]
            ok = True
            try:
                rest_post(f"/channels/{channel}/messages", {"content": content})
            except Exception as e:
                ok = False
                log(f"[discord] send failed: {e}")
            bus_pub("delivery/discord/sent", {"channel_id": channel, "ok": ok})
        except Exception as e:
            log(f"[discord] bad send event: {e}")
    sys.exit(1)  # bus subscription died -> crash-only restart


def main():
    if not TOKEN:
        park("DISCORD_TOKEN not set")
    try:
        import websockets.sync.client as ws_client
    except ImportError:
        park("python3 `websockets` package not installed")

    threading.Thread(target=outbound_loop, daemon=True).start()

    ws = ws_client.connect(GATEWAY)
    hello = json.loads(ws.recv())
    interval = hello["d"]["heartbeat_interval"] / 1000.0
    seq = None

    def heartbeat():
        while True:
            time.sleep(interval)
            ws.send(json.dumps({"op": 1, "d": seq}))

    threading.Thread(target=heartbeat, daemon=True).start()
    ws.send(json.dumps({
        "op": 2,
        "d": {
            "token": TOKEN,
            # GUILDS | GUILD_MESSAGES | DIRECT_MESSAGES | MESSAGE_CONTENT
            "intents": (1 << 0) | (1 << 9) | (1 << 12) | (1 << 15),
            "properties": {"os": "elanus", "browser": "elanus", "device": "elanus"},
        },
    }))
    log("[discord] gateway connected, identifying")

    for raw in iter(ws.recv, None):
        msg = json.loads(raw)
        seq = msg.get("s") or seq
        if msg.get("op") == 1:  # server-requested heartbeat
            ws.send(json.dumps({"op": 1, "d": seq}))
        elif msg.get("t") == "MESSAGE_CREATE":
            d = msg["d"]
            if d.get("author", {}).get("bot"):
                continue
            inbound = {
                "channel_id": d.get("channel_id"),
                "author": d.get("author", {}).get("username"),
                "text": d.get("content", ""),
                "message_id": d.get("id"),
            }
            bus_pub("ingress/discord/message", inbound, qos=0)
            bus_pub("work/discord/triage", inbound, qos=1)
    sys.exit(1)  # gateway closed -> crash-only restart


if __name__ == "__main__":
    main()
