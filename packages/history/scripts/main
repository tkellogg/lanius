#!/usr/bin/env python3
"""history — reconstruction-view daemon: read-only history queries over the bus.

Doctrine (docs/bus.md, [DECIDED] flight recorder vs reconstruction views):
the ledger and transcripts in sqlite are the truth; views that rebuild
reality from them are userland subscribers. This is the first one. It holds
NO state of its own — every query is answered by a fresh read-only sqlite
connection, so the answer is exactly as good as the ledger at that instant.

Protocol (request/response over the obs plane — fan-out only, never ledger):

  query    -> obs/ui/history/q      {"kind": ..., "qid": "<requester-minted>", ...}
  response -> obs/ui/history/r/<qid>  {"qid": ..., "ok": true, ...} | {"qid":..., "ok": false, "error": ...}

Query kinds:
  agents                          -> {"agents":[{"agent","sessions":[...]}], "orphan_sessions":[...]}
  sessions     {agent?}           -> {"sessions":[{"session","first_ts","last_ts","message_count","event_count"}]}
  transcript   {session, limit?, before_id?}
                                  -> {"session","messages":[{"id","role","content","event_id","created_at"}],"has_more"}
  conversation {correlation}      -> {"correlation","events":[{"id","type","cause_id","state","payload","created_at"}],"truncated"}

Bus access rides the `elanus bus` CLI as subprocesses (the linemux/discord
pattern); the CLI authenticates from the supervisor-injected env, so this
script holds no bus credentials. Crash-only: a dead subscription or a failed
response publish exits nonzero and the supervisor restarts us with backoff.
"""
import json
import os
import sqlite3
import subprocess
import sys
import time

DB = os.environ.get("HARNESS_DB") or os.path.join(os.environ.get("HARNESS_ROOT", "."), "harness.db")
Q_TOPIC = "obs/ui/history/q"
R_PREFIX = "obs/ui/history/r/"

PAGE_DEFAULT = 80      # transcript page size if the requester doesn't say
PAGE_MAX = 200         # hard cap — responses are single MQTT publishes
CONTENT_CAP = 16 * 1024  # per-message content cap; bigger gets a preview stub
CONV_CAP = 500         # conversation event cap


def log(msg):
    print(msg, file=sys.stderr, flush=True)


def ro():
    """Fresh READ-ONLY connection per query. mode=ro is load-bearing: a view
    must be physically unable to write the truth it reconstructs."""
    conn = sqlite3.connect(f"file:{DB}?mode=ro", uri=True, timeout=5)
    conn.row_factory = sqlite3.Row
    return conn


def capped_json(text):
    """Parse stored JSON; oversized content becomes an honest stub instead of
    an oversized publish that the broker (or a browser tab) chokes on."""
    if text is None:
        return None
    if len(text) > CONTENT_CAP:
        return {"truncated": True, "chars": len(text), "preview": text[:2048]}
    try:
        return json.loads(text)
    except (ValueError, TypeError):
        return text


def agent_of(event_type):
    """in/agent/<noun>[/<conversation>...] -> noun, else None."""
    seg = (event_type or "").split("/")
    return seg[2] if len(seg) >= 3 and seg[0] == "in" and seg[1] == "agent" else None


# ---- query kinds ------------------------------------------------------------

def q_agents(c, q):
    nouns = set()
    for (t,) in c.execute("SELECT DISTINCT type FROM events WHERE type LIKE 'in/agent/%'"):
        a = agent_of(t)
        if a:
            nouns.add(a)
    by_agent = {n: set() for n in nouns}
    orphans = set()
    rows = c.execute(
        """SELECT DISTINCT m.session_id, e.type
           FROM messages m LEFT JOIN events e ON m.event_id = e.id"""
    )
    for sid, etype in rows:
        a = agent_of(etype)
        if a:
            by_agent.setdefault(a, set()).add(sid)
            orphans.discard(sid)
        elif not any(sid in s for s in by_agent.values()):
            orphans.add(sid)
    return {
        "agents": [{"agent": a, "sessions": sorted(by_agent[a])} for a in sorted(by_agent)],
        "orphan_sessions": sorted(orphans - {s for v in by_agent.values() for s in v}),
    }


def q_sessions(c, q):
    agent = q.get("agent")
    sql = """SELECT m.session_id AS session, MIN(m.created_at) AS first_ts,
                    MAX(m.created_at) AS last_ts, COUNT(*) AS message_count,
                    COUNT(DISTINCT m.event_id) AS event_count
             FROM messages m"""
    params = []
    if agent:
        sql += """ WHERE EXISTS (
                     SELECT 1 FROM messages m2 JOIN events e ON m2.event_id = e.id
                     WHERE m2.session_id = m.session_id
                       AND (e.type = 'in/agent/' || ?1 OR e.type LIKE 'in/agent/' || ?1 || '/%'))"""
        params.append(agent)
    sql += " GROUP BY m.session_id ORDER BY last_ts DESC LIMIT 500"
    return {"sessions": [dict(r) for r in c.execute(sql, params)]}


def q_transcript(c, q):
    session = q.get("session")
    if not session:
        raise ValueError("transcript needs {session}")
    limit = max(1, min(int(q.get("limit") or PAGE_DEFAULT), PAGE_MAX))
    before = q.get("before_id")
    sql = "SELECT id, role, content, event_id, created_at FROM messages WHERE session_id = ?"
    params = [session]
    if before is not None:
        sql += " AND id < ?"
        params.append(int(before))
    sql += " ORDER BY id DESC LIMIT ?"
    params.append(limit + 1)  # one extra row = honest has_more
    rows = list(c.execute(sql, params))
    has_more = len(rows) > limit
    rows = rows[:limit]
    rows.reverse()  # chronological for the reader
    return {
        "session": session,
        "messages": [
            {"id": r["id"], "role": r["role"], "content": capped_json(r["content"]),
             "event_id": r["event_id"], "created_at": r["created_at"]}
            for r in rows
        ],
        "has_more": has_more,
    }


def q_conversation(c, q):
    corr = q.get("correlation")
    if not corr:
        raise ValueError("conversation needs {correlation}")
    rows = list(c.execute(
        """SELECT id, type, cause_id, state, payload, created_at
           FROM events WHERE correlation_id = ? ORDER BY id ASC LIMIT ?""",
        (corr, CONV_CAP + 1),
    ))
    truncated = len(rows) > CONV_CAP
    rows = rows[:CONV_CAP]
    return {
        "correlation": corr,
        "events": [
            {"id": r["id"], "type": r["type"], "cause_id": r["cause_id"], "state": r["state"],
             "payload": capped_json(r["payload"]), "created_at": r["created_at"]}
            for r in rows
        ],
        "truncated": truncated,
    }


KINDS = {"agents": q_agents, "sessions": q_sessions,
         "transcript": q_transcript, "conversation": q_conversation}


# ---- wire -------------------------------------------------------------------

def valid_qid(qid):
    """qid becomes one topic segment of the response topic; reject anything
    that could change the topic shape or smuggle a wildcard."""
    return (isinstance(qid, str) and 0 < len(qid) <= 128
            and not any(ch in qid for ch in "/+#\x00") and qid.isprintable())


def respond(qid, body):
    body["qid"] = qid
    # QoS 1: PUBACK means the broker took it; obs/# still never ledgers.
    subprocess.run(
        ["elanus", "bus", "pub", R_PREFIX + qid, json.dumps(body), "--qos", "1"],
        check=True, timeout=30,
    )


def handle(query):
    qid = query.get("qid")
    if not valid_qid(qid):
        log(f"[history] dropping query with bad qid: {query.get('qid')!r}")
        return  # no valid response topic exists; nothing to answer on
    kind = query.get("kind")
    fn = KINDS.get(kind)
    if fn is None:
        respond(qid, {"ok": False, "error": f"unknown kind {kind!r}", "kinds": sorted(KINDS)})
        return
    try:
        with ro() as c:
            body = fn(c, query)
        body["ok"] = True
        body["kind"] = kind
        respond(qid, body)
    except subprocess.SubprocessError:
        raise  # bus trouble is crash-only, not a per-query error
    except Exception as e:  # bad args, sqlite hiccups: the requester's problem
        respond(qid, {"ok": False, "kind": kind, "error": str(e)})


def sub_grant_approved():
    """The broker checks subscribe grants at SUBACK time but the CLI cannot
    see a denied SUBACK — a too-early subscribe would hang silently holding
    nothing. So park until the grant is visibly approved (ledger reads are
    open by design); `elanus approve history` flips this without a restart
    dance."""
    try:
        with ro() as c:
            row = c.execute(
                "SELECT state FROM grants WHERE package = ? AND kind = 'subscribe' AND value = ?"
                " ORDER BY id DESC LIMIT 1",
                (os.environ.get("ELANUS_PACKAGE", "history"), Q_TOPIC),
            ).fetchone()
        return row is not None and row["state"] == "approved"
    except sqlite3.Error:
        return False


def main():
    if not os.path.exists(DB):
        log(f"[history] no ledger at {DB}; parking is wrong here — the path is "
            "supervisor-given, so a missing db is a real fault")
        sys.exit(1)
    waited = False
    while not sub_grant_approved():
        if not waited:
            log(f"[history] subscribe grant on {Q_TOPIC} not approved yet; "
                "parking until `elanus approve history` (this is not an error)")
            waited = True
        time.sleep(2)
    proc = subprocess.Popen(["elanus", "bus", "sub", Q_TOPIC], stdout=subprocess.PIPE, text=True)
    log(f"[history] serving {Q_TOPIC} -> {R_PREFIX}<qid> (db {DB}, read-only)")
    for line in proc.stdout:
        try:
            query = json.loads(line).get("payload") or {}
            # the broker fans obs publishes out inside a trace envelope
            # ({"kind": <topic>, "payload": <published JSON>, "ts": ...});
            # the query is the inner payload. A bare query (no envelope)
            # also works — it carries its own qid.
            if isinstance(query, dict) and "qid" not in query and isinstance(query.get("payload"), dict):
                query = query["payload"]
            if not isinstance(query, dict):
                continue
        except ValueError:
            continue
        handle(query)
    log("[history] bus subscription died -> exiting for restart")
    sys.exit(1)


if __name__ == "__main__":
    main()
